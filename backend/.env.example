# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# When running via docker-compose, DATABASE_URL is built automatically from the
# POSTGRES_* variables below. Fill manually only when running outside Docker.
DATABASE_URL=postgresql://sbrtask:CHANGE_ME@localhost:5432/sbrtask

# ── PostgreSQL (docker-compose only) ─────────────────────────────────────────
POSTGRES_DB=sbrtask
POSTGRES_USER=sbrtask
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Development: http://localhost:5173
# Production:  https://sbrtask.laboratoriosobral.com
CORS_ORIGIN=https://sbrtask.laboratoriosobral.com

# ── AD/LDAP — Laboratório Sobral ──────────────────────────────────────────────
LDAP_URL=ldap://dc.labsobralnet.ind:389
LDAP_DOMAIN=labsobralnet.ind
LDAP_BASE_DN=DC=labsobralnet,DC=ind
LDAP_SERVICE_DN=CN=ServiceAccount,OU=Usuarios,DC=labsobralnet,DC=ind
LDAP_SERVICE_PASS=

# IPs da rede interna (vírgula separados). Vazio = sem restrição de acesso remoto.
COMPANY_IPS=
